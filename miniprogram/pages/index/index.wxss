.container {
  padding: 20px;
  padding-bottom: 40px;
}

/* 标题区域 */
.header {
  margin-bottom: 24px;
}

.title-row {
  display: flex;
  align-items: center;
}

.title {
  font-size: 32px;
  margin-right: 12px;
}

.title-text-wrap {
  display: flex;
  flex-direction: column;
}

.subtitle {
  font-size: 14px;
  color: #999999;
}

.main-title {
  font-size: 28px;
  font-weight: 700;
  color: #333333;
}

/* 区块 */
.section {
  padding: 16px;
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
  color: #333333;
}

/* 上传按钮区域 */
.upload-btn-row {
  display: flex;
  gap: 12px;
}

.upload-btn-album,
.upload-btn-camera {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 120px;
  border-radius: 12px;
  font-weight: 600;
}

.upload-btn-album {
  background: linear-gradient(135deg, #4A90E2 0%, #667EEA 100%);
  box-shadow: 0 4px 16px rgba(74, 144, 226, 0.4);
}

.upload-btn-camera {
  background: linear-gradient(135deg, #F2994A 0%, #F2C94C 100%);
  box-shadow: 0 4px 16px rgba(242, 153, 74, 0.4);
}

.upload-btn-icon {
  font-size: 36px;
  margin-bottom: 8px;
}

.upload-btn-text {
  font-size: 14px;
  color: #FFFFFF;
}

/* 预览区域 */
.preview-area {
  position: relative;
  width: 100%;
  height: 200px;
  border-radius: 12px;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 28px;
  height: 28px;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #FFFFFF;
}

/* 参考图上传区域 */
.reference-upload-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.reference-upload-item {
  position: relative;
  width: 100px;
  height: 100px;
  border-radius: 12px;
  overflow: hidden;
}

.reference-upload-empty {
  background: #F5F7FA;
  border: 2px dashed #D0D7E2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reference-image {
  width: 100%;
  height: 100%;
}

.reference-remove-btn {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 24px;
  height: 24px;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #FFFFFF;
}

.reference-add-icon {
  font-size: 32px;
  color: #BBBBBB;
}

/* 标签 */
.tags-wrap {
  display: flex;
  flex-wrap: wrap;
}

/* 提示词区域 - 磨砂质感 */
.prompt-area {
  background: linear-gradient(135deg, rgba(74, 144, 226, 0.06) 0%, rgba(102, 126, 234, 0.06) 50%, rgba(74, 144, 226, 0.03) 100%);
  border: 1px solid rgba(74, 144, 226, 0.12);
  border-radius: 16px;
  padding: 16px;
  position: relative;
  overflow: hidden;
}

.prompt-area::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 10px,
    rgba(74, 144, 226, 0.02) 10px,
    rgba(74, 144, 226, 0.02) 20px
  );
  pointer-events: none;
}

.prompt-input {
  width: 100%;
  height: 120px;
  font-size: 14px;
  color: #333333;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(74, 144, 226, 0.1);
  border-radius: 12px;
  padding: 12px;
  line-height: 1.6;
  box-sizing: border-box;
}

.prompt-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12px;
}

.char-count {
  font-size: 12px;
  color: #999999;
  background: rgba(255, 255, 255, 0.5);
  padding: 4px 8px;
  border-radius: 6px;
}

.ai-generate-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 20px;
  background: linear-gradient(135deg, #4A90E2 0%, #667EEA 100%);
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
  color: #FFFFFF;
  box-shadow: 0 4px 12px rgba(74, 144, 226, 0.4);
  border: none;
  transition: all 0.3s ease;
}

.ai-generate-btn-loading {
  opacity: 0.85;
  box-shadow: 0 2px 8px rgba(74, 144, 226, 0.3);
  pointer-events: none;
}

.ai-icon {
  font-size: 16px;
}

/* Loading spinner 动画 */
.ai-loading-spinner {
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 生成按钮 */
.btn-wrap {
  margin-top: 24px;
  margin-bottom: 40px;
}

.generate-btn {
  width: 100%;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}
