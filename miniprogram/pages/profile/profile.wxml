<view class="profile-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar-large">
      <view class="avatar-ring {{isMember ? 'ring-member' : ''}}">
        <text class="avatar-emoji">👤</text>
      </view>
    </view>
    <view class="user-info">
      <text class="user-phone">{{isLoggedIn ? phone : '未登录'}}</text>
      <view class="user-tag {{isMember ? 'tag-member' : 'tag-free'}}">
        <text>{{isMember ? '会员用户' : '免费用户'}}</text>
      </view>
    </view>
  </view>

  <!-- 会员状态 -->
  <view class="section">
    <view class="section-title">会员状态</view>
    <view class="status-card {{isMember ? 'status-active' : 'status-inactive'}}">
      <view class="status-row">
        <text class="status-label">{{isMember ? '会员有效至' : '当前状态'}}</text>
        <text class="status-value">{{isMember ? expireTime : '未开通'}}</text>
      </view>
      <view class="status-row" wx:if="{{!isMember && isLoggedIn}}">
        <text class="status-label">剩余免费次数</text>
        <text class="status-value">{{freeLimit - freeUsed}}/{{freeLimit}}</text>
      </view>
      <view class="status-row" wx:if="{{!isLoggedIn}}">
        <text class="status-label">剩余免费次数</text>
        <text class="status-value">{{freeLimit - freeUsed}}/{{freeLimit}}</text>
      </view>
    </view>
  </view>

  <!-- 操作列表 -->
  <view class="section">
    <view class="section-title">操作</view>

    <!-- 登录（未登录时显示） -->
    <view class="menu-item" wx:if="{{!isLoggedIn}}" bindtap="onLogin">
      <text class="menu-icon">📱</text>
      <text class="menu-label">手机号登录</text>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 卡密兑换 -->
    <view class="menu-item" bindtap="showCardKeyInput">
      <text class="menu-icon">🎫</text>
      <text class="menu-label">卡密兑换</text>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 退出登录 -->
    <view class="menu-item menu-danger" wx:if="{{isLoggedIn}}" bindtap="onLogout">
      <text class="menu-icon">🚪</text>
      <text class="menu-label">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 卡密输入区（展开时） -->
  <view class="cardkey-section" wx:if="{{showCardKey}}">
    <view class="cardkey-title">输入卡密</view>
    <view class="cardkey-form">
      <input 
        class="cardkey-input" 
        placeholder="请输入卡密，如 VIP-AB3D-K9F2" 
        value="{{cardKeyInput}}" 
        bindinput="onCardKeyInput"
        placeholderStyle="color: #BBBBBB"
      />
      <view class="cardkey-btn" bindtap="onVerifyCardKey">确认兑换</view>
    </view>
  </view>

  <!-- 底部版本信息 -->
  <view class="version-info">
    <text>AI漫剧大师 v1.0</text>
  </view>
</view>

<!-- 登录弹窗（未登录时卡密兑换也用这个） -->
<view class="modal-mask" wx:if="{{showLoginModal}}" bindtap="hideLogin"></view>
<view class="login-modal {{showLoginModal ? 'show' : ''}}">
  <view class="login-modal-title">登录</view>
  <view class="login-modal-desc">授权手机号即可登录，享受无限次生成</view>
  <button class="login-phone-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
    <text class="login-phone-icon">📱</text>
    <text>手机号快捷登录</text>
  </button>
  <view class="login-modal-close" bindtap="hideLogin">取消</view>
</view>
