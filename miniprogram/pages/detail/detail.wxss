.container {
  padding: 20px;
  padding-bottom: 40px;
}

/* 图片预览区域 */
.image-section {
  margin-bottom: 20px;
}

.detail-image {
  width: 100%;
  height: 400px;
  border-radius: 16px;
  background: #F5F7FA;
}

.image-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 12px;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 16px;
  background: #F5F7FA;
  border: 1px solid #E8ECF1;
  border-radius: 20px;
  font-size: 14px;
  color: #666666;
  border: none;
}

.share-btn {
  margin: 0;
  padding: 10px 16px;
  line-height: 1.4;
}

.share-btn::after {
  border: none;
}

.action-icon {
  font-size: 16px;
}

/* 原图区域 */
.source-section {
  margin-bottom: 20px;
  padding: 16px;
}

.source-label {
  font-size: 14px;
  font-weight: 600;
  color: #666666;
  margin-bottom: 12px;
}

.source-image {
  width: 100%;
  height: 200px;
  border-radius: 12px;
  background: #F5F7FA;
}

/* 参考图区域 */
.reference-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.reference-image {
  width: calc(33.33% - 8px);
  height: 100px;
  border-radius: 12px;
  background: #F5F7FA;
}

/* 批量图片缩略图 */
.batch-thumbs {
  margin-bottom: 20px;
}

.batch-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  font-size: 14px;
  color: #666666;
}

.save-all-btn {
  padding: 6px 14px;
  background: #4A90E2;
  border-radius: 16px;
  font-size: 12px;
  color: #FFFFFF;
}

.thumbs-scroll {
  width: 100%;
  white-space: nowrap;
}

.thumbs-list {
  display: inline-flex;
  gap: 12px;
  padding: 4px 0;
}

.thumb-item {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: 12px;
  overflow: hidden;
  border: 3px solid transparent;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.thumb-active {
  border-color: #4A90E2;
  box-shadow: 0 2px 12px rgba(74, 144, 226, 0.4);
}

.thumb-image {
  width: 100%;
  height: 100%;
}

.thumb-index {
  position: absolute;
  top: 4px;
  left: 4px;
  width: 20px;
  height: 20px;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: #FFFFFF;
}

/* 信息卡片 */
.info-card {
  padding: 20px;
}

.info-row {
  display: flex;
  margin-bottom: 20px;
}

.info-item {
  flex: 1;
}

.info-item.full-width {
  flex: none;
  width: 100%;
}

.info-label {
  display: block;
  font-size: 14px;
  color: #999999;
  margin-bottom: 6px;
}

.info-value {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #333333;
}

/* 分隔线 */
.divider {
  height: 1px;
  background: #E8ECF1;
  margin: 20px 0;
}

/* 提示词区域 */
.prompt-section {
  margin-top: 4px;
}

.prompt-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.prompt-title {
  font-size: 16px;
  font-weight: 600;
  color: #4A90E2;
}

.copy-btn {
  padding: 6px 12px;
  background: #F5F7FA;
  border: 1px solid #E8ECF1;
  border-radius: 8px;
  font-size: 14px;
  color: #666666;
}

.prompt-content {
  padding: 16px;
  background: #F5F7FA;
  border-radius: 12px;
  font-size: 14px;
  line-height: 1.8;
  color: #333333;
}
