/* 全局样式 - 简约蓝白风格 */
page {
  background-color: #F5F7FA;
  color: #333333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 玻璃卡片样式 - 浅色版 */
.glass-card {
  background: #FFFFFF;
  border: 1px solid #E8ECF1;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}

/* 渐变按钮 */
.gradient-btn {
  background: linear-gradient(135deg, #4A90E2 0%, #5BA0E8 100%);
  border: none;
  border-radius: 12px;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  padding: 16px;
  box-shadow: 0 4px 16px rgba(74, 144, 226, 0.3);
}

.gradient-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 14px;
  margin: 0 8px 8px 0;
}

.tag-default {
  background: #F5F7FA;
  border: 1px solid #E8ECF1;
  color: #666666;
}

.tag-active {
  background: #4A90E2;
  border: 1px solid #4A90E2;
  color: #FFFFFF;
}

/* 区块标题 */
.section-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
}
